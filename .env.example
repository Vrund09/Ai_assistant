# ============================================================
# Voice → Internet → Speaking Avatar Assistant
# Copy this file to .env and fill in your API keys.
# .env is gitignored — never commit real keys!
# ============================================================

# Required — LLM (Groq — free tier, 30+ req/min)
# Get yours free at: https://console.groq.com
GEMINI_API_KEY=your_groq_api_key_here

# Required — photorealistic talking avatar (WebRTC)
# Sign up at: https://www.simli.com
# $10 free signup credit / 50 free min/month
SIMLI_API_KEY=your_simli_api_key_here
SIMLI_FACE_ID=your_simli_face_id_here

# Optional — only needed if Simli doesn't accept text directly
# ElevenLabs free tier: https://elevenlabs.io
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional — general web search (stretch goal)
# Tavily free tier: https://tavily.com
# TAVILY_API_KEY=your_tavily_api_key_here

# Optional — general web search alternative
# Serper free tier: https://serper.dev
# SERPER_API_KEY=your_serper_api_key_here

# Development flag — set to "true" to use mocked responses
# (burns zero API quota during dev iteration)
MOCK_MODE=false
